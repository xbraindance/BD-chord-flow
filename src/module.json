{
    "api_version": 1,
    "id": "chord-flow",
    "name": "Chord Flow",
    "abbrev": "CF",
    "version": "0.6.5",
    "author": "Magnus Liljebergh",
    "builtin": false,
    "ui": "ui.js",
    "dsp": "dsp.so",
    "component_type": "midi_fx",
    "chainable": true,
    "capabilities": {
        "chainable": true,
        "component_type": "midi_fx",
        "raw_midi": true
    },
    "chain_params": [
        {
            "key": "pad",
            "name": "Pad",
            "type": "int",
            "min": 1,
            "max": 32,
            "step": 1
        },
        {
            "key": "root",
            "name": "Root",
            "type": "enum",
            "options": ["c", "c#", "d", "d#", "e", "f", "f#", "g", "g#", "a", "a#", "b"]
        },
        {
            "key": "chord_type",
            "name": "Chord",
            "type": "enum",
            "options": [
                "maj", "min", "5th", "sus2", "sus4", "add2", "add4", "add9", "add11",
                "6th", "min6", "69", "m69", "maj7", "min7", "dom7", "maj9", "min9", "dom9",
                "dim", "dim7", "m7b5", "aug", "aug7", "sus7", "7sus2", "7sus4", "sus4add9",
                "9sus", "sus9", "11th", "m11", "sus11", "13th", "maj13", "min13",
                "dom7add9", "dom7b9", "dom7#9", "dom7#5", "dom7b5", "dom7#11", "dom7alt", "maj7#5", "maj7b5", "maj7#11", "maj9#11",
                "madd4", "madd9", "madd11", "mb5", "mb6", "m7b13", "m7add11", "m7add13", "m7b9b5", "m11b5", "mM7", "mM7add11", "mM13", "sus13", "add13",
                "11sus", "11sus2", "13b9", "5add9", "5b9", "6sus2", "6sus2b5", "6sus4", "7#9#5", "9#11",
                "dimM7", "dim#5", "dim11", "addb9", "aug#9", "mb7", "mb9", "mb13", "m6addb13",
                "no3", "no5", "maj7add6", "maj7sus2", "maj9no3", "maj6"
            ]
        },
        {
            "key": "inversion",
            "name": "Inversion",
            "type": "enum",
            "options": ["root", "1st", "2nd", "3rd"]
        },
        {
            "key": "bass",
            "name": "Bass",
            "type": "enum",
            "options": ["none", "c", "c#", "d", "d#", "e", "f", "f#", "g", "g#", "a", "a#", "b"]
        },
        {
            "key": "pad_octave",
            "name": "Pad Oct",
            "type": "int",
            "min": -6,
            "max": 6,
            "step": 1
        },
        {
            "key": "strum",
            "name": "Strum",
            "type": "int",
            "min": 0,
            "max": 100,
            "step": 1
        },
        {
            "key": "strum_dir",
            "name": "Str Dir",
            "type": "enum",
            "options": ["up", "down"]
        },
        {
            "key": "articulation",
            "name": "Art",
            "type": "enum",
            "options": ["off", "on"]
        },
        {
            "key": "reverse_art",
            "name": "Rev Art",
            "type": "enum",
            "options": ["off", "on"]
        },
        {
            "key": "global_octave",
            "name": "Global Oct",
            "type": "int",
            "min": -6,
            "max": 6,
            "step": 1
        },
        {
            "key": "global_transpose",
            "name": "Global Trans",
            "type": "int",
            "min": -12,
            "max": 12,
            "step": 1
        }
    ],
    "assets": {
        "path": "presets",
        "label": "Presets",
        "extensions": [
            ".json"
        ],
        "optional": true,
        "description": "Upload additional preset bank JSON files."
    }
}
